# Shared across all services — copy to .env and fill in real values
# Never commit .env to git

# Database (RDS in prod, local MySQL in dev)
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret

# JWT — use a long random string in prod
JWT_SECRET=change-me-to-a-long-random-string

# Default admin account (created automatically on first user-service boot)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Super Admin

# Laravel APP_KEY for each PHP service (base64:32-random-bytes)
# Leave blank → auto-generated on first container boot (dev only)
# Generate: php artisan key:generate --show
PRODUCT_APP_KEY=
PAYMENT_APP_KEY=

# AWS (for ECR push / EKS deploy)
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
ECR_BASE=
