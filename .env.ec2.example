# ── EC2 Production Environment ────────────────────────────────────────────────
# Copy this to .env.ec2 on your EC2 instance and fill in all values.
# NEVER commit .env.ec2 to git.

# ECR base URL  (format: <account-id>.dkr.ecr.<region>.amazonaws.com)
ECR_BASE=123456789012.dkr.ecr.us-east-1.amazonaws.com

# RDS MySQL (create these in AWS RDS console)
RDS_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
RDS_USER=admin
RDS_PASSWORD=YourStrongPassword123!

# JWT secret (generate: openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-secret

# RabbitMQ credentials
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Admin user seeded into user-service on first boot
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Super Admin

# Laravel app keys (generate: php artisan key:generate --show, or use any base64:... string)
PRODUCT_APP_KEY=base64:replace-with-32-byte-base64-string=
PAYMENT_APP_KEY=base64:replace-with-32-byte-base64-string=
